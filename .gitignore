# ──────────────────────────────────────────────────────────────
# AgToosa .gitignore
# ──────────────────────────────────────────────────────────────

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
desktop.ini
*~

# ── IDEs & Editors ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Node.js ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.env

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Build artifacts ──────────────────────────────────────────
dist/
build/
*.egg-info/

# ── AgToosa Generated Output ────────────────────────────────
ship/
