{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgToosa Extension and Preset Catalog",
  "type": "object",
  "required": ["schema_version", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "entries": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "id", "kind", "name", "summary", "tags", "examples",
        "maintainers", "support", "lifecycle", "reviewed_at",
        "compatibility", "trust"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "kind": { "enum": ["extension", "preset"] },
        "name": { "type": "string", "maxLength": 256 },
        "summary": { "type": "string", "maxLength": 4096 },
        "tags": { "type": "array", "items": { "type": "string" } },
        "examples": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "maintainers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "contact"],
            "properties": {
              "name": { "type": "string" },
              "contact": { "type": "string" }
            }
          }
        },
        "support": { "type": "string" },
        "lifecycle": { "enum": ["maintained", "experimental", "deprecated"] },
        "reviewed_at": { "type": "string" },
        "compatibility": {
          "type": "object",
          "required": ["agtoosa", "platforms", "requires", "conflicts"],
          "properties": {
            "agtoosa": { "type": "string" },
            "platforms": { "type": "array", "items": { "type": "string" } },
            "requires": { "type": "array", "items": { "type": "string" } },
            "conflicts": { "type": "array", "items": { "type": "string" } }
          }
        },
        "trust": {
          "type": "object",
          "required": ["curation_tier", "registry_verified_snapshot", "review_status"],
          "properties": {
            "curation_tier": { "type": "string" },
            "registry_verified_snapshot": { "type": "boolean" },
            "review_status": { "type": "string" }
          }
        },
        "provenance": {
          "type": "object",
          "required": ["registry_name", "version", "source", "sha256", "signature"],
          "properties": {
            "registry_name": { "type": "string" },
            "version": { "type": "string" },
            "source": { "type": "string" },
            "sha256": { "type": "string" },
            "signature": { "type": "string" }
          }
        },
        "members": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "required": ["extension_id", "rationale"],
            "properties": {
              "extension_id": { "type": "string" },
              "rationale": { "type": "string" }
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "extension" } } },
          "then": { "required": ["provenance"] }
        },
        {
          "if": { "properties": { "kind": { "const": "preset" } } },
          "then": { "required": ["members"] }
        }
      ]
    }
  }
}
